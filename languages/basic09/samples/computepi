PROCEDURE arctaner
PARAM x, result: REAL
DIM term, sign: REAL
DIM i: INTEGER
term := x
result := 0.0
sign := 1.0
FOR i = 0 TO 24
  result := result + sign * term / (2 * i + 1)
  term := term * x * x
  sign := -sign
NEXT i
END

PROCEDURE computePi
DIM a5, a239, myPi: REAL
RUN arctaner(0.2, a5)
RUN arctaner(1.0 / 239.0, a239)
myPi := 4.0 * (4.0 * a5 - a239)
PRINT "Pi (Machin) ="; myPi
PRINT "Reference   ="; PI
PRINT "Error       ="; ABS(myPi - PI)
END
