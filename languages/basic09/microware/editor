 bsr MOVUP
 ldd P.SYMB,X
 subd P.DSCB,X Calculate description table size
 subd #3
 std I.DSCS
 addd I.DSCR
 addd #3 Compute new symbol tbl addr
 std I.SYMT
 ldd P.SIZE,X
 subd P.SYMB,X
 addd #3 Compute symbol tbl size
 std I.SYMS
