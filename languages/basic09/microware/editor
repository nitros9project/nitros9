***************
* Debug State Entry Point
*   Process Debugging Commands

*  Called by Interpreter during execution of
*  a procedure.  I.Dots are set up, and must be
*  maintained, as well as Opstack and I.Stbg.
*  All registers should be unchanged upon return,
*  with the execption of CC.

DEBUG pshs D,X,Y,U Preserve registers
 lda I.ERR
 cmpa #M$SSOV System stack overflow?
 beq HALT ..Yes; exit
 tst DEBUGGER already in Debugger?
 bne CONTIN99 ..Yes; don't enter recursively
 inc DEBUGGER Signal Debugger Entered
 lda G.SIGN Abort signal recieved?
 bne DEBUG9 ..Yes; don't check step count
 ldd STEPS in step mode?
 subd #1 (decrement step count)
 bhi NXSTEP ..not expired; continue stepping
 bmi DEBUG2 ..Yes; don't reprint header
DEBUG1 lbsr NEWLIN Clean up I/O buffer
 leax DBGMSG,PCR Get debug message
 lbsr STRSPC
 lbsr PAPRCN Print active procedure name
DEBUG2 leax DBGPMT,PCR Get prompt string
 leay DBGVRB,PCR Get debug verb table ptr
 lbsr RUNCMD Execute debug command
 bcc DEBUG2 Repeat
 lda G.SIGN (keyboadr abort) signal received?
 bne DEBUG9 ..Yes; go check out
 lbsr CMDERR print "WHAT?"
 bra DEBUG2 Repeat

DEBUG9 cmpa #S$Abort Keyboard abort?
 bne DEBUG1 ..no; enter debug mode

***************
* Halt
*   Abort execution and return to command mode

HALT lbsr J$TROF Insure trace is turned off
 lda #3
HALT10 cmpa BASOUT command output path?
 beq HALT20 ..Yes; don't close it
 OS9 I$Close Close all but std I/O paths
HALT20 inca
 cmpa #NumPaths
 blo HALT10
 lbra EXIT Return to command mode

***************
* Subroutine Step
*   Enter single step mode

STEPM lbsr CMDSEP Get comma or space
 bne STEP1 Default one step
 leax  ,Y Tell asnm where to get the number
 lbsr GETNUM Get number
 bcc STEP2 No error -continue
 rts ERROR - return carry set

NXSTEP bsr STEP2 (will not return)
STEP0 clrb
 bra STEP15
STEP1 ldb #1 Use default
STEP15 clra
STEP2 std STEPS
 lsl I.RUNM
 coma set Carry
 ror I.RUNM Request another pause
 bra CONTI1 (continue interpretation)

***************
* Subroutine Contin
*   Continue execution of suspended procedure

CONTIN lbsr NEWLIN Reset I/O ptrs
 lsl I.RUNM
 lsr I.RUNM Clear break flag
 ldd #1
 std STEPS
CONTI1 leas 2,S discard DEBUG's return addr
 clr DEBUGGER signal NOT in debugger
CONTIN99 puls D,X,Y,U,PC Restore interpreter's registers and return

***************
* Trcexp
*   Trace expression

* This routine is called by statement dispatch
* instead of the Expression Interpreter when
* in Trace mode.

TRCEXP ldy J$EVAL+3 Get address of expr interp.
 jsr  ,Y Interpret expression
PRTEXP pshs D,X,Y,U Save registers
 cmpy I.OPBG
 beq TRCE99

* What About Expression Errors & Condition Codes?

 ldb I.IOCT Save I/O state
 ldx I.IOBG
 ldu I.IOPT
 pshs B,X,U
 stu I.IOBG
 lbsr NEWLIN
 lda #'= Trace expression indicator
 lbsr PUTCHR
 ldb  ,Y Get type byte
 addb #V$PRBY Adjust for cnvio
 cmpb #V$INLN Bad type?
 bhs TRCEX9 ..Yes; dont print it
 leax  ,Y Copy opstack ptr
 lbsr DCVALU Print value
TRCEX9 lbsr PRTEOL Print buffer (clears carry)
 puls B,X,U Restore I/O state
 stb I.IOCT
 stx I.IOBG
 stu I.IOPT
TRCE99 puls D,X,Y,U,PC Restore regs & return

***************
* Subroutine Lstbnd
*   List Currently active, Bound procedure

LSTBND lbsr PCURPC Print active procedure name
 tst P.STAT,X Compiled procedure?
 bmi LSTBN9 ..mum's the word
 ldx I.ICBG
LSTBN0 clr I.OCNT Reset pretty print indentation

LSTBN1 tst G.SIGN (abort) signal?
 bne LSTBN9 ..Yes; exit
 leay  ,X Copy icode ptr
 lbsr NXTONE Find address of beginning of next line
 bsr LSTBLN List the line
 exg X,Y
 cmpx I.ICLM
 blo LSTBN1
 cmpx I.ICPT
 bne LSTBN9
 cmpy I.ICLM End of icode?
 blo LSTBN1 ..no
LSTBN9 clra clear Carry
 rts

***************
* Subroutine Lstbln
*   List bound I-Code line

* Passed: (X) - I-Code ptr to Line to List
*         (Y) - I-Code ptr to End of Line +1
* Destroys: D

LSTBLN pshs X,Y,U Save caller's registers
 lbsr NEWLIN
 ldx I.APRC
 tst P.STAT,X is this a compiled procedure?
 bmi LSTB99 ..nice try, but no answers out of me
 ldx  ,S Restore i-code ptr
 tfr Y,D
 subd  ,S Size of icode line to list
 bmi LSTBL9 None - return
 pshs D,X Save regs
 addd #64 Estimate opstack requirement of decompiler
 cmpd G.VARS Enough free space?
 lbhs ERMFUL ..no; abort
 tst PRTCTL Silent (save) mode?
 bmi LSTBL3 Skip address stuff
 lda #V$SPAC
 cmpx I.ICPT Above current line?
 bhi LSTBL2 ..Yes
 beq LSTBL1 At current line
 cmpy I.ICPT in current line?
 bls LSTBL2 ..no
LSTBL1 lda #'* Mark current line
LSTBL2 lbsr PUTCHR
 cmpx I.ICLM End of procedure?
 bhs LSTBL3 ..Yes; exit
 tfr X,D
 subd I.ICBG Get offset address of line
 ldx I.IOPT
 lbsr J$PHEX Put it in I/O buffer
 lda #V$SPAC
 sta ,X+
 stx I.IOPT
 lbsr OUTBUF
LSTBL3 puls D,Y
 cmpy I.ICLM End of icode?
 bhs LSTBL9 ..Yes; dont print line
 ldu I.STBG
 lbsr MOVUP Copy line to free memory
 lbsr SVCRIT Save sensitive data
 stu I.ICPT
 leax D,U
 stx I.ICLM
 stx I.STBG
 leay  ,U Beginning of copied line
 tst PRTCTL Silent (save) mode?
 bmi LSTBL5 ..Yes; don't print "ERR"
 leax  ,Y Copy icode ptr
 lbsr CHKERR Error line?
 bne LSTBL5 ..No; don't print "ERR"
LSTBL4 leax ERRR,PCR get "ERR" msg
 lbsr PRTSTR
LSTBL5 lbsr NEWLIN
 lbsr UNBICD Unbind the line
 lbsr DCLINE Decompile the line
 bsr RSCRIT Restore sensitive data
 dec I.IOPT+1
LSTBL9 lbsr PRTEOL
LSTB99 puls X,Y,U,PC Restore registers and return

***************
* Subroutine Direxq
*   Process Direct Execution statement

DIREXQ ldx I.APRC
 tst P.STAT,X is this a compiled procedure?
 bpl DIREX1 ..no; ok!
 coma COMPILER Can't handle compiled state
 rts

DIREX1 ldy I.IOBG
 lbsr J$CMPL Compile the line
 bsr SVCRIT Save critical global variables
 ldx I.STBG
 lbsr CHKERR Did the compiler generate an error line?
 beq RSCRIT ..Yes; return (restore critical variables first)
 stx I.ICBG
 stx I.ICPT
 leay  ,X
 ldx ICDPTR
 stx I.ICLM
 stx I.STBG
 lbsr J$BSTM Bind compiled statement
 ldx I.APRC
 lda P.STAT,X
 clr P.STAT,X
 tsta ANY Binder errors?
 bne RSCRIT ..Yes; avoid running
 leax <RSCRIT,PCR
 lbsr SETEXT Set error exit for interpreter
 ldx I.ICBG
 lbsr J$ISTM Interpret statement
 lbra EXIT Exit (this will fall through to restore critical variables)

***************
* Subroutine Rscrit
*   Restore critical suspension state variables from Opstack

RSCRIT pshs D,X,Y,U
 ldu I.OPBG Get stack ptr
 pulu D,X,Y
 sty G.PRCS
 stx G.VARS
 std I.STBG
 pulu D,X,Y
 sty I.ICLM
 stx I.ICBG
 std I.ICPT
RSCRI1 stu I.OPBG
 stu I.OPSP
 clra (return carry clear)
 puls D,X,Y,U,PC return

***************
* Subroutine Svcrit
*   Save critical suspension state variables on Opstack

SVCRIT pshs D,X,Y,U
 ldu I.OPBG Get opstack ptr
 ldd I.ICPT
 ldx I.ICBG
 ldy I.ICLM
 pshu D,X,Y
 ldd I.STBG
 ldx G.VARS
 ldy G.PRCS
 pshu D,X,Y
 bra RSCRI1

***************
* Subroutine State
*   Print current procedure, followed by caller, and
*    so on until Top level procedure has been reached

STATE ldy I.ASTR Get active procedure's u.dots
 leax PRCEDR,PCR
STATE1 bsr NLIN
 lbsr STRSPC
 ldx U.PROC,Y Get this procedure's address
 bsr PRTNAM Print this procedure's name
 leax CALLBY,PCR
 ldy U.U,Y Get caller's u.dots
 bne STATE1 Repeat until top level is found
NLIN lbra NEWLIN

***************
* Subroutine Break
*   Set pause on return to higher level procedure

BREAK lbsr J$NAME is there a name in the command line?
 beq BREAK9 ..no; error
 lbsr DIRSCH is it in the procedure directory?
 bcs BREAK9 ..no; error
 ldx  ,X Get addr of desired procedure
 ldy I.ASTR
BREAK1 ldy U.U,Y Get next previous procedure storage
 beq BREAK9 None found - error
 cmpx U.PROC,Y is it the desired one?
 bne BREAK1 ..no; loop until it is
 lsl U.RUNM,Y
 coma set Pause in run mode
 ror U.RUNM,Y
 leax OKMSG,PCR get "OK"
 bra PRTLIN

BREAK9 coma (return Carry set)
 rts

***************
* Subroutine PRTNAM
*   Print current procedure name

* Passed: (X)=Address of Procedure Whose Name is Desired
* Destroys: None

PCURPC bsr NLIN
PAPRCN leax PRCEDR,PCR get "PROCEDURE"
 lbsr STRSPC Put it in I/O buffer
 ldx I.APRC Get active procedure ptr

PRTNAM pshs X Save
 leax P.NAME,X Get ptr to name string
 bsr STREOL Print the name (followed by crlf)
 puls X,PC Return

***************
* Subroutine PRTLIN
*   Print Line

* Passed: (X)=String ptr
* Returns: Nothing Useful
* Destroys: A,X,CC

PRTLIN bsr NLIN reset I/O ptrs
STREOL lbsr CPYSTR
PRTEOL lbsr PUTCR put EOL in buffer
 bsr OUTBUF
 bra NLIN

PRTSTR bsr NLIN
 lbsr CPYSTR

OUTBUF pshs D,X,Y Save regs
 ldd I.IOPT
 subd I.IOBG Length of string in I/O buffer
 bls PRTEXT exit if none
 tfr D,Y
 ldx I.IOBG
 lda #CMDOUT
 OS9 I$WritLn
 bcc PRTEXT
 bsr PRTERR Print error msg
PRTEXT puls D,X,Y,PC return

 endc

