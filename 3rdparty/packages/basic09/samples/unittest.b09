PROCEDURE testIntegerArithmetic
PARAM passed,failed:INTEGER
DIM actual:INTEGER

actual:=2+3*4
IF actual=14 THEN
PRINT "PASS integer precedence"
passed:=passed+1
ELSE
PRINT "FAIL integer precedence: expected 14 got ";actual
failed:=failed+1
ENDIF

actual:=(20-5)/3
IF actual=5 THEN
PRINT "PASS integer grouping"
passed:=passed+1
ELSE
PRINT "FAIL integer grouping: expected 5 got ";actual
failed:=failed+1
ENDIF

END

PROCEDURE testRealArithmetic
PARAM passed,failed:INTEGER
DIM actual:REAL

actual:=10.0/4.0
IF ABS(actual-2.5)<.0001 THEN
PRINT "PASS real division"
passed:=passed+1
ELSE
PRINT "FAIL real division: expected 2.5 got ";actual
failed:=failed+1
ENDIF

actual:=(1.5+2.25)*2.0
IF ABS(actual-7.5)<.0001 THEN
PRINT "PASS real expression"
passed:=passed+1
ELSE
PRINT "FAIL real expression: expected 7.5 got ";actual
failed:=failed+1
ENDIF

END

PROCEDURE testStringFunctions
PARAM passed,failed:INTEGER
DIM sample:STRING[20]

sample:="BASIC"+"09"
IF LEN(sample)=7 THEN
PRINT "PASS string length"
passed:=passed+1
ELSE
PRINT "FAIL string length: expected 7 got ";LEN(sample)
failed:=failed+1
ENDIF

IF LEFT$(sample,5)="BASIC" AND RIGHT$(sample,2)="09" THEN
PRINT "PASS string slices"
passed:=passed+1
ELSE
PRINT "FAIL string slices"
failed:=failed+1
ENDIF

END

PROCEDURE testArrayIndexing
PARAM passed,failed:INTEGER
DIM i,sum,values(5):INTEGER

sum:=0
FOR i:=1 TO 5
values(i):=i*2
sum:=sum+values(i)
NEXT i

IF sum=30 THEN
PRINT "PASS array indexing"
passed:=passed+1
ELSE
PRINT "FAIL array indexing: expected 30 got ";sum
failed:=failed+1
ENDIF

END

PROCEDURE testBooleanLogic
PARAM passed,failed:INTEGER
DIM flag:BOOLEAN

flag:=TRUE
IF flag AND NOT(FALSE) THEN
PRINT "PASS boolean logic"
passed:=passed+1
ELSE
PRINT "FAIL boolean logic"
failed:=failed+1
ENDIF

END

PROCEDURE testRecordFields
TYPE pair=left:INTEGER; right:INTEGER
PARAM passed,failed:INTEGER
DIM sample:pair

sample.left:=12
sample.right:=30
IF sample.left+sample.right=42 THEN
PRINT "PASS record fields"
passed:=passed+1
ELSE
PRINT "FAIL record fields: expected 42 got ";sample.left+sample.right
failed:=failed+1
ENDIF

END

PROCEDURE testRepeatUntil
PARAM passed,failed:INTEGER
DIM count,total:INTEGER

count:=0
total:=0
REPEAT
count:=count+1
total:=total+count
UNTIL count=5

IF total=15 THEN
PRINT "PASS repeat until"
passed:=passed+1
ELSE
PRINT "FAIL repeat until: expected 15 got ";total
failed:=failed+1
ENDIF

END

PROCEDURE runTests
DIM passed,failed:INTEGER

passed:=0
failed:=0

PRINT "BASIC09 unit tests"
PRINT "------------------"

RUN testIntegerArithmetic(passed,failed)
RUN testRealArithmetic(passed,failed)
RUN testStringFunctions(passed,failed)
RUN testArrayIndexing(passed,failed)
RUN testBooleanLogic(passed,failed)
RUN testRecordFields(passed,failed)
RUN testRepeatUntil(passed,failed)

PRINT "------------------"
PRINT "Passed: ";passed
PRINT "Failed: ";failed

END
