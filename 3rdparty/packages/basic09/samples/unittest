passed:=passed+1
ELSE
PRINT "FAIL repeat once: expected 100 got ";i
failed:=failed+1
ENDIF

i:=0
LOOP
i:=i+1
EXITIF i=3 THEN
ENDEXIT
ENDLOOP
IF i=3 THEN
PRINT "PASS loop exitif"
passed:=passed+1
ELSE
PRINT "FAIL loop exitif: expected 3 got ";i
failed:=failed+1
ENDIF

END

