modem /wz
echo AT+CIPMUX=1>/wz
modem /wz
echo AT+CIPMODE=1>/wz
modem /wz
echo AT+CIPSERVER=1,23>/wz
modem /wz
echo AT+CIPSTO=0>/wz
modem /wz
echo * Done
