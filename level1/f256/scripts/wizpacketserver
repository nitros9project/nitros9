echo * WizFi360 Helper - Start packet server for /n# devices
xmode /wz eko=0
echo ATE0>/wz
mergeln /wz /wz
echo AT+CIPMODE=0>/wz
mergeln /wz /wz
echo AT+CIPMUX=1>/wz
mergeln /wz /wz
echo AT+CIPSERVERMAXCONN=4>/wz
mergeln /wz /wz
echo AT+CIPSERVER=1,23>/wz
mergeln /wz /wz
echo AT+CIPSTO=0>/wz
mergeln /wz /wz /wz
echo * Done
